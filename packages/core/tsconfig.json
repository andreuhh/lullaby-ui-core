{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "strict": true,
        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": true,
        "moduleResolution": "Bundler",
        "declaration": true,
        "skipLibCheck": true,
        "outDir": "dist"
    },
    "include": [
        "src"
    ]
}